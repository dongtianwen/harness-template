#!/bin/bash
# Harness pre-commit hook
# 自动安装：bootstrap/init-project.sh 会把此文件复制到 .git/hooks/pre-commit

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

PASS=0
FAIL=0

check() {
  local desc=$1
  local result=$2
  if [ "$result" = "ok" ]; then
    echo -e "  ${GREEN}✅${NC} $desc"
    PASS=$((PASS + 1))
  else
    echo -e "  ${RED}❌${NC} $desc — $result"
    FAIL=$((FAIL + 1))
  fi
}

echo ""
echo "🔍 Harness pre-commit 检查..."
echo ""

# 检查1：STATE.md 是否在本次提交中更新
if git diff --cached --name-only | grep -q "STATE.md"; then
  check "STATE.md 已更新" "ok"
else
  check "STATE.md 已更新" "本次提交未包含 STATE.md，请更新后再提交"
fi

# 检查2：任务文件命名格式
INVALID_TASKS=$(git diff --cached --name-only | grep "^tasks/task-" | grep -v -E "^tasks/task-[0-9]{3}\.md$" | grep -v "task-template" | grep -v "task-maintenance" || true)
if [ -z "$INVALID_TASKS" ]; then
  check "任务文件命名规范" "ok"
else
  check "任务文件命名规范" "以下文件命名不符合 task-{三位数}.md 格式：$INVALID_TASKS"
fi

# 检查3：新增报告文件命名格式
INVALID_REPORTS=$(git diff --cached --name-only | grep "^reports/" | grep -v "README" | grep -v "delivery-summary" | grep -v "maintenance" | grep -v -E "^reports/report-task-[0-9]{3}-[0-9]{4}-[0-9]{2}-[0-9]{2}\.md$" || true)
if [ -z "$INVALID_REPORTS" ]; then
  check "报告文件命名规范" "ok"
else
  check "报告文件命名规范" "以下文件命名不符合 report-task-{id}-{YYYY-MM-DD}.md 格式：$INVALID_REPORTS"
fi

# 检查4：关键目录是否存在
MISSING_DIRS=""
for dir in docs tasks reports src logs workspace; do
  if [ ! -d "$dir" ]; then
    MISSING_DIRS="$MISSING_DIRS $dir"
  fi
done
if [ -z "$MISSING_DIRS" ]; then
  check "关键目录完整" "ok"
else
  check "关键目录完整" "缺少目录：$MISSING_DIRS"
fi

# 检查5：AGENTS.md 和 PRD.md 存在
MISSING_FILES=""
for f in AGENTS.md PRD.md PROMPTS.md; do
  if [ ! -f "$f" ]; then
    MISSING_FILES="$MISSING_FILES $f"
  fi
done
if [ -z "$MISSING_FILES" ]; then
  check "核心文件存在" "ok"
else
  check "核心文件存在" "缺少文件：$MISSING_FILES"
fi

echo ""
echo "结果：${PASS} 项通过，${FAIL} 项失败"
echo ""

if [ "$FAIL" -gt 0 ]; then
  echo -e "${RED}提交被拒绝，请修复以上问题后重新提交。${NC}"
  echo -e "${YELLOW}如需强制提交（不推荐）：git commit --no-verify${NC}"
  echo ""
  exit 1
else
  echo -e "${GREEN}所有检查通过，提交成功。${NC}"
  echo ""
  exit 0
fi
